---
import { Image } from 'astro:assets';

interface Badge {
  variant: 'type' | 'live' | 'soon' | 'platform';
  label: string;
}
interface Stat {
  value: string;
  label: string;
}
interface Cta {
  type: 'link' | 'soon';
  href?: string;
  label: string;
}
interface Props {
  title: string;
  images?: string;
  badges: Badge[];
  description: string;
  tags: string[];
  stats: Stat[];
  cta: Cta;
}

const { title, images, badges, description, tags, stats, cta } = Astro.props;

// Carga (optimizada) de todas las imágenes bajo src/assets.
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/**/*.{webp,png,jpg,jpeg,avif}',
  { eager: true }
);

// Deriva la carpeta ("../../assets/habits" -> "habits") y filtra sus imágenes.
const folder = images?.split('/').filter(Boolean).pop() ?? '';
const slides = folder
  ? Object.entries(allImages)
      .filter(([path]) => path.includes(`/assets/${folder}/`))
      .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
      .map(([, mod]) => mod.default)
  : [];

// id único para enlazar el JS del carrusel con este card concreto.
const carouselId = `car-${folder || 'x'}-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="product-card">
  <div class="card-meta">
    {badges.map((badge) => <span class={`badge badge-${badge.variant}`}>{badge.label}</span>)}
  </div>

  {slides.length > 0 && (
    <>
      {/* Portada: solo se descarga esta imagen al cargar la página */}
      <button class="cover" data-open={carouselId} aria-label={`Ver capturas de ${title}`}>
        <Image
          src={slides[0]}
          alt={`${title} — captura 1`}
          loading="lazy"
          widths={[320, 640]}
          sizes="(max-width: 640px) 90vw, 400px"
        />
        {slides.length > 1 && (
          <span class="cover-hint">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 3 21 3 21 9" /><polyline points="9 21 3 21 3 15" />
              <line x1="21" y1="3" x2="14" y2="10" /><line x1="3" y1="21" x2="10" y2="14" />
            </svg>
            {slides.length} capturas
          </span>
        )}
      </button>

      {/* Modal: display:none hasta abrir → las otras imágenes NO se piden aún */}
      <dialog class="carousel-modal" id={carouselId} data-carousel aria-label={`Capturas de ${title}`}>
        <button class="modal-close" data-close aria-label="Cerrar">×</button>
        <div class="carousel-track" data-track>
          {slides.map((img, i) => (
            <div class="carousel-slide">
              <Image
                src={img}
                alt={`${title} — captura ${i + 1}`}
                loading="lazy"
                widths={[640, 1080]}
                sizes="(max-width: 720px) 92vw, 640px"
              />
            </div>
          ))}
        </div>

        {slides.length > 1 && (
          <>
            <button class="carousel-btn prev" data-prev aria-label="Anterior">‹</button>
            <button class="carousel-btn next" data-next aria-label="Siguiente">›</button>
            <div class="carousel-dots" data-dots>
              {slides.map((_, i) => (
                <button
                  class:list={['carousel-dot', { active: i === 0 }]}
                  data-dot={i}
                  aria-label={`Ir a la imagen ${i + 1}`}
                />
              ))}
            </div>
          </>
        )}
      </dialog>
    </>
  )}

  <div>
    <div class="card-title" translate="no" data-notranslate="true">{title}</div>


    <div class="card">
    <p class="card-desc" style="margin-top:0.5rem">{description}</p>
    </div>
  </div>
  <div class="card-tags">
    {tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
  <div class="card-stats">
    {stats.map((stat) => (
      <div class="stat">
        <span class="stat-val">{stat.value}</span>
        <span class="stat-lbl">{stat.label}</span>
      </div>
    ))}
  </div>
  {cta.type === 'link' ? (
    <a href={cta.href} class="card-cta" target="_blank" rel="noopener">{cta.label}</a>
  ) : (
    <span class="card-cta-soon">{cta.label}</span>
  )}
</div>

<style>
  .product-card {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(252deg, rgb(255, 255, 255), rgba(255, 255, 255, 0.01) 38%, rgba(255, 255, 255, 0.06) 50%, rgba(255, 255, 255, 0.01) 62%, rgba(255, 255, 255, 0.04)),
      var(--card);
    padding: 2rem;
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    animation: centralGlow 6s ease-in-out infinite;
  }

  .product-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      60deg,
      transparent 0%,
      rgba(255, 255, 255, 0) 50%,
      rgb(255, 255, 255) 100%,
      rgb(0, 0, 0) 50%,
      transparent 100%
    );
    filter: blur(18px) saturate(1.35) brightness(1.1);
    mix-blend-mode: screen;
    transform: translateX(-6%);
    animation:
      centerLine 6.5s ease-in-out infinite,
      boltHue 18s ease-in-out infinite;
    pointer-events: none;
  }

  .product-card > * {
    position: relative;
    z-index: 1;
  }


  @keyframes centerLine {
    0%,
    100% {
      transform: translateX(-14%) scaleX(0.96);
    }
    50% {
      transform: translateX(14%) scaleX(1.04);
    }
  }

  .product-card:hover {
    border: 1px solid #47ff2f;
    box-shadow: 0 0 0 1px rgba(255, 92, 43, 0.06), 0 12px 48px rgba(255, 92, 43, 0.07);
    transform: translateY(-2px);
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }
  .card-title {
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--text);
  }
  .card-desc {
    font-size: 0.875rem;
    color: #25eeff;
    line-height: 1.78;
  }
  .card-stats {
    display: flex;
    gap: 1.75rem;
    flex-wrap: wrap;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }
  .stat { display: flex; flex-direction: column; gap: 0.08rem; }
  .stat-val {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--text);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.025em;
  }
  .stat-lbl {
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .card-tags { display: flex; gap: 0.45rem; flex-wrap: wrap; }
  
  .tag {
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.18rem 0.55rem;
    color: var(--muted);
  }
  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    padding: 0.62rem 1.35rem;
    border-radius: 9px;
    width: fit-content;
    margin-top: auto;
    transition: opacity 0.15s, transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 20px rgba(255, 92, 43, 0.3);
  }
  .card-cta:hover {
    opacity: 0.92;
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(255, 92, 43, 0.4);
  }
  .card-cta:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .card-cta-soon {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    color: var(--muted);
    border: 1px dashed rgba(255, 255, 255, 0.14);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    padding: 0.62rem 1.35rem;
    border-radius: 9px;
    width: fit-content;
    margin-top: auto;
  }
  .card-soon {
    background: transparent;
    border: 1px dashed rgba(255, 255, 255, 0.07);
    border-radius: 14px;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 0.6rem;
    min-height: 200px;
  }
  .soon-title { font-size: 0.88rem; font-weight: 700; color: var(--dim); }
  .soon-sub { font-size: 0.78rem; color: var(--dim); line-height: 1.68; }
  @media (prefers-reduced-motion: reduce) {
    .card-cta, .product-card { transition: none; }
  }

  /* ---- Portada (en la card) ---- */
  .cover {
    position: relative;
    width: 100%;
    padding: 10px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    cursor: pointer;
    max-height: 420px;
  }
  .cover :global(img) {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s;
  }
  .cover:hover :global(img) { transform: scale(1.04); }
  .cover:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .cover-hint {
    position: absolute;
    bottom: 0.6rem;
    right: 0.6rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: #fff;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    padding: 0.28rem 0.55rem;
    border-radius: 7px;
  }

  /* ---- Modal + carrusel ---- */
  .carousel-modal {
    /* Centrado en el viewport (patrón fiable para <dialog>) */
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(92vw, calc(90vh * 9 / 16));
    max-width: 92vw;
    max-height: 90vh;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--card);
    overflow: hidden;
  }
  .carousel-modal::backdrop {
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(2px);
  }
  .carousel-modal[open] { display: block; }
  .carousel-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
  }
  .carousel-track::-webkit-scrollbar { display: none; }
  .carousel-slide {
    flex: 0 0 100%;
    scroll-snap-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .carousel-slide :global(img) {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    display: block;
  }
  .modal-close {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    z-index: 2;
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border: none;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
  }
  .modal-close:hover { background: var(--accent); }
  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    border: none;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.2s;
  }
  .carousel-btn:hover { background: var(--accent); }
  .carousel-btn.prev { left: 0.5rem; }
  .carousel-btn.next { right: 0.5rem; }
  .carousel-dots {
    position: absolute;
    bottom: 0.6rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.4rem;
  }
  .carousel-dot {
    width: 7px;
    height: 7px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  .carousel-dot.active {
    background: var(--accent);
    transform: scale(1.25);
  }
  @media (prefers-reduced-motion: reduce) {
    .carousel-track { scroll-behavior: auto; }
    .carousel-btn, .cover :global(img) { transition: none; }
  }
</style>

<script>
  function initCarousels() {
    // Enlaza cada portada con su modal y lo abre/cierra.
    document.querySelectorAll<HTMLButtonElement>('[data-open]').forEach((btn) => {
      if (btn.dataset.ready) return;
      btn.dataset.ready = 'true';
      const modal = document.getElementById(btn.dataset.open!) as HTMLDialogElement | null;
      if (!modal) return;
      btn.addEventListener('click', () => modal.showModal());
      modal.querySelector('[data-close]')?.addEventListener('click', () => modal.close());
      // Cerrar al tocar el fondo (backdrop).
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.close();
      });
    });

    // Lógica del carrusel (flechas + puntos).
    document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((car) => {
      if (car.dataset.ready) return;
      car.dataset.ready = 'true';

      const track = car.querySelector<HTMLElement>('[data-track]');
      if (!track) return;
      const slides = Array.from(track.children) as HTMLElement[];
      const dots = Array.from(car.querySelectorAll<HTMLElement>('[data-dot]'));
      if (slides.length < 2) return;

      const goTo = (i: number) => {
        const idx = (i + slides.length) % slides.length;
        track.scrollTo({ left: slides[idx].offsetLeft });
      };
      const current = () => Math.round(track.scrollLeft / track.clientWidth);

      car.querySelector('[data-prev]')?.addEventListener('click', () => goTo(current() - 1));
      car.querySelector('[data-next]')?.addEventListener('click', () => goTo(current() + 1));
      dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

      // Sincroniza los puntos con el scroll.
      let raf = 0;
      track.addEventListener('scroll', () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const idx = current();
          dots.forEach((d, i) => d.classList.toggle('active', i === idx));
        });
      });
    });
  }

  initCarousels();
  document.addEventListener('astro:page-load', initCarousels);
</script>
