---
import PolicyBlock from '../PolicyBlock.astro';
import PolicySection from '../PolicySection.astro';
---

<PolicyBlock
  id="privacy-arcane-spheres"
  title="Arcane Spheres"
  badgeLabel="Privacy Policy"
  updated="July 5, 2026"
>
  <PolicySection heading="Overview">
    <p>
      Ball Studios ("we", "our") operates the mobile application
      <strong>Arcane Spheres</strong> (package ID:
      <code>com.ballstudio.ArcaneSpheres</code>).
      This document describes how data is collected and used when you play the game.
    </p>
  </PolicySection>

  <PolicySection heading="Data we collect">
    <p>
      Arcane Spheres does not collect personal information through its own systems.
      All game progress — current level, earned shards and crystals, unlocked spheres
      and upgrades, equipped sphere and cosmetic skin, and settings — is stored locally
      on your device and is never transmitted to our servers.
    </p>
  </PolicySection>

  <PolicySection heading="Advertising">
    <p>
      The App uses <strong>Google AdMob</strong> to display advertisements, including
      banner ads, interstitial ads (between matches and on game over), and optional
      rewarded ads (to revive after a run or double level-clear rewards). AdMob may
      collect data to serve personalized ads, including:
    </p>
    <ul>
      <li>Device identifiers (Advertising ID)</li>
      <li>IP address and approximate location</li>
      <li>Interaction data with displayed ads</li>
      <li>App usage information</li>
    </ul>
    <p style="margin-top:0.75rem">
      Users in the <strong>EEA and UK</strong> are shown a consent dialog powered by
      <strong>Google's User Messaging Platform (UMP)</strong> before personalized ads
      are served. You may withdraw consent at any time through your device settings
      under <em>Privacy → Ads</em>. Google's data practices are governed by
      <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Google's Privacy Policy</a>.
    </p>
  </PolicySection>

  <PolicySection heading="Children's privacy">
    <p>
      The App is not directed at children under 13. We do not knowingly collect personal
      data from children. If you believe a child has provided personal information,
      contact us and we will delete it promptly.
    </p>
  </PolicySection>

  <PolicySection heading="Lawful basis (EEA & UK)">
    <p>
      Ball Studios does not process personal data through its own systems for this App.
      Advertising data processed by Google AdMob relies on your <strong>consent</strong>
      (EEA/UK users, via Google's UMP) or <strong>legitimate interest</strong>
      (non-personalized ads). Local game data on your device is not subject to GDPR.
    </p>
  </PolicySection>

  <PolicySection heading="Your rights">
    <p>Depending on your location, you may have the following rights:</p>
    <ul>
      <li><strong>Access</strong> — request a copy of personal data held about you</li>
      <li><strong>Erasure</strong> — request deletion of your data</li>
      <li><strong>Objection</strong> — object to processing based on legitimate interest</li>
      <li><strong>Opt-out of data sharing</strong> (California) — opt out of ad data sharing via device settings</li>
    </ul>
    <p style="margin-top:0.75rem">
      All game data is local. Use <em>Reset Progress</em> or uninstall the App to delete it.
      For AdMob-related requests write to <a href="mailto:lsalazarbedon@gmail.com">lsalazarbedon@gmail.com</a> — we will respond within 30 days.
    </p>
  </PolicySection>

  <PolicySection heading="Data retention">
    <p>
      Ball Studios retains no personal data on its servers. Game data persists on your device
      until you uninstall the App or reset progress. AdMob data retention is governed by
      <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Google's Privacy Policy</a>.
    </p>
  </PolicySection>

  <PolicySection heading="Contact">
    <p>
      Questions about this policy:
      <a href="mailto:lsalazarbedon@gmail.com">lsalazarbedon@gmail.com</a>
    </p>
  </PolicySection>
</PolicyBlock>
