---
import PolicyBlock from '../PolicyBlock.astro';
import PolicySection from '../PolicySection.astro';
---

<PolicyBlock
  id="privacy-rolling-escape"
  title="Rolling Escape"
  badgeLabel="Privacy Policy"
  updated="June 24, 2026"
>
  <PolicySection heading="Overview">
    <p>
      Ball Studios ("we", "our") operates the mobile application
      <strong translate="no" data-notranslate="true">Rolling Escape</strong>. This document describes how data is
      collected and used when you play the game.
    </p>
  </PolicySection>

  <PolicySection heading="Data we collect">
  <div class="flex">
    <p translate="no" data-notranslate="true">Rolling Escape</p> 
    <p>
        does not collect personal information through its own
        systems. All game progress — score, coins, owned skins, checkpoint level
        — is stored locally on your device and is never transmitted to our servers.
    </p>
  </div>
  </PolicySection>

  <PolicySection heading="Advertising">
    <p>
      The App uses <strong>Google AdMob</strong> to display advertisements.
      AdMob may collect data to serve personalized ads, including:
    </p>
    <ul>
      <li>Device identifiers (Advertising ID)</li>
      <li>IP address and approximate location</li>
      <li>Interaction data with displayed ads</li>
      <li>App usage information</li>
    </ul>
    <p style="margin-top:0.75rem">
      Users in the <strong>EEA and UK</strong> are shown a consent dialog powered by
      <strong>Google's User Messaging Platform (UMP)</strong> before personalized ads
      are served. You may withdraw consent at any time through your device settings
      under <em>Privacy → Ads</em>. Google's data practices are governed by
      <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Google's Privacy Policy</a>.
    </p>
  </PolicySection>

  <PolicySection heading="Children's privacy">
    <p>
      The App is not directed at children under 13. We do not knowingly
      collect personal data from children. Contact us if you believe a child
      has provided personal information and we will delete it promptly.
    </p>
  </PolicySection>

  <PolicySection heading="Data deletion">
    <p>
      Local game data can be removed at any time by uninstalling the App or
      using the <em>Reset Progress</em> option in the game settings.
    </p>
  </PolicySection>

  <PolicySection heading="Lawful basis (EEA & UK)">
    <p>
      Ball Studios does not process personal data through its own systems for this App.
      Advertising data processed by Google AdMob is based on your <strong>consent</strong>
      (EEA/UK users, via Google's UMP dialog) or <strong>legitimate interest</strong>
      (non-personalized ads). Local game data stored on your device is not subject to GDPR.
    </p>
  </PolicySection>

  <PolicySection heading="Your rights">
    <p>Depending on your location, you may have the following rights:</p>
    <ul>
      <li><strong>Access</strong> — request a copy of personal data held about you</li>
      <li><strong>Erasure</strong> — request deletion of your data ("right to be forgotten")</li>
      <li><strong>Objection</strong> — object to processing based on legitimate interest</li>
      <li><strong>Opt-out of data sharing</strong> (California/CCPA) — AdMob data sharing may qualify as a "sale" under CCPA; opt out via your device ad settings</li>
    </ul>
    <p style="margin-top:0.75rem">
      All game data is stored locally. Use <em>Reset Progress</em> or uninstall the App
      to delete it. For AdMob-related rights, write to
      <a
        class="about-cta"
        href="https://docs.google.com/forms/d/e/1FAIpQLScMVe3zWAij_TeCoYU03qG2ggQVVJMWYmuq8J1hfybdmcohpg/viewform"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Open Ball Studios questionnaire"
      >
        Contact
      </a> and we will assist within 30 days.
    </p>
  </PolicySection>

  <PolicySection heading="Data retention">
    <p>
      Ball Studios retains no personal data on its servers. Game data persists on your device
      until you uninstall the App or use <em>Reset Progress</em>. AdMob data retention is
      governed by <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Google's Privacy Policy</a>.
    </p>
  </PolicySection>

  <PolicySection heading="Contact">
    <p>
      Questions about this policy:
      <a
        class="about-cta"
        href="https://docs.google.com/forms/d/e/1FAIpQLScMVe3zWAij_TeCoYU03qG2ggQVVJMWYmuq8J1hfybdmcohpg/viewform"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Open Ball Studios questionnaire"
      >
        Contact
      </a>
    </p>
  </PolicySection>
</PolicyBlock>
